# ShadowFit AI Server 환경 변수

# 디버그 모드 (운영 환경에서는 false)
DEBUG=true

# MediaPipe 모델 복잡도 (0=lite, 1=full, 2=heavy)
POSE_MODEL_COMPLEXITY=1

# 포즈 감지 최소 신뢰도
POSE_MIN_DETECTION_CONFIDENCE=0.5
POSE_MIN_TRACKING_CONFIDENCE=0.5

# 영상 전처리 시 분석할 FPS
VIDEO_PROCESS_FPS=10

# Spring Boot 백엔드 URL
BACKEND_URL=http://localhost:8080/api/v1

# CORS 허용 출처 (쉼표 구분)
CORS_ORIGINS=["*"]
